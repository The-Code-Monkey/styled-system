{
  "version": "0.1.2",
  "license": "MIT",
  "name": "@aw-web-design/styled-system",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=12"
  },
  "scripts": {
    "start": "tsdx watch",
    "build": "tsdx build",
    "test": "tsdx test",
    "lint": "tsdx lint",
    "prepare": "tsdx build",
    "size": "size-limit",
    "analyze": "size-limit --why"
  },
  "peerDependencies": {},
  "husky": {
    "hooks": {
      "pre-commit": "tsdx lint"
    }
  },
  "prettier": {
    "printWidth": 80,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "author": "The-Code-Monkey",
  "module": "dist/styled-system.esm.js",
  "size-limit": [
    {
      "path": "dist/styled-system.cjs.production.min.js",
      "limit": "10 KB"
    },
    {
      "path": "dist/styled-system.esm.js",
      "limit": "10 KB"
    }
  ],
  "devDependencies": {
    "@size-limit/preset-small-lib": "^4.12.0",
    "husky": "^6.0.0",
    "size-limit": "^4.12.0",
    "tsdx": "^0.14.1",
    "tslib": "^2.2.0",
    "typescript": "^4.3.2"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.1.0",
    "@emotion/memoize": "^0.7.5",
    "csstype": "^3.0.8"
  }
}
